# Anthropic API — key from https://console.anthropic.com/ (starts with sk-ant-)
ANTHROPIC_API_KEY=sk-ant-replace-me

# --- Telegram bot connector ---
# Token from @BotFather (Telegram app): send /newbot, then paste the token here.
TELEGRAM_BOT_TOKEN=replace-me
# true  = high-confidence replies are sent automatically
# false = EVERY reply queues for human review first (safe default for cold-start + demo)
AUTO_SEND_ENABLED=false

# --- Confidence Net ---
CONFIDENCE_THRESHOLD=0.90

# getUpdates long-poll timeout (seconds)
POLL_INTERVAL_SEC=30

# Models — cheap for routing, premium for drafting
INTENT_MODEL=claude-haiku-4-5-20251001
DRAFT_MODEL=claude-sonnet-4-6

# Local SQLite for dev; swap to a Postgres DSN on Railway.
DATABASE_URL=sqlite:///data/agent.db

# Railway multi-service role: poller | dashboard | web
SERVICE_ROLE=poller

WIKI_DIR=wiki/products
LOG_LEVEL=INFO
